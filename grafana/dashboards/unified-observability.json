{
  "uid": "unified-observability",
  "title": "Unified Observability Dashboard",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "type": "timeseries",
      "title": "Request Rate",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(http_server_requests_total[5m]))", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error Rate",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(http_server_requests_total{status=~\"5..\"}[5m])) / sum(rate(http_server_requests_total[5m]))", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency p95",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket[5m])) by (le))", "refId": "A" }
      ]
    },
    {
      "type": "logs",
      "title": "Correlated Logs (Loki)",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "expr": "{service_name=\"sample-api\"}", "refId": "A" }
      ]
    },
    {
      "type": "traces",
      "title": "Correlated Traces (Tempo)",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 10 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "queryType": "traceqlSearch",
          "query": "{resource.service.name = \"sample-api\"}",
          "refId": "A"
        }
      ]
    }
  ]
}
